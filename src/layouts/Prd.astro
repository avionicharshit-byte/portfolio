---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  tagline: string;
  insight: string;
  northStar: string;
  pdfPath?: string;
}

const { title, tagline, insight, northStar, pdfPath } = Astro.props;
---

<Base title={`${title} PRD — Harshit Dev Yadav`} description={tagline}>
  <Nav />

  <main class="pt-28 pb-16">
    <div class="max-w-wide mx-auto px-6 md:px-10">

      <a href="/#specs" class="font-mono text-xs text-muted hover:text-ink transition-colors uppercase tracking-wide inline-flex items-center gap-1 mb-12">
        ← All specs
      </a>

      <header class="mb-16 animate-in" style="animation-delay: 0ms">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="font-mono text-xs text-muted bg-paper border border-rule px-2 py-0.5 rounded-sm uppercase tracking-widest">PRD</span>
        </div>

        <h1 class="font-display text-display-xl text-ink mb-4 max-w-[22ch] text-balance">
          {title}
        </h1>
        <p class="text-muted text-lg max-w-measure mb-8">{tagline}</p>

        <!-- Insight block -->
        <div class="border-l-[3px] border-accent pl-6 py-2 mb-8 max-w-measure">
          <p class="font-mono text-xs text-muted uppercase tracking-wide mb-2">Core insight</p>
          <p class="text-ink leading-relaxed italic">"{insight}"</p>
        </div>

        <div class="flex flex-wrap items-center gap-6 mb-8">
          <div>
            <p class="font-mono text-xs text-muted uppercase tracking-wide mb-1">North-star metric</p>
            <p class="font-mono text-accent text-sm font-semibold">{northStar}</p>
          </div>
        </div>

        {pdfPath && (
          <a
            href={pdfPath}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-mono text-sm text-ink border border-ink/20 px-4 py-2 rounded-sm hover:border-ink hover:bg-ink hover:text-paper transition-all duration-150"
          >
            Download PDF ↓
          </a>
        )}
      </header>

      <article class="prose-case animate-in" style="animation-delay: 100ms">
        <slot />
      </article>

    </div>
  </main>

  <Footer />
</Base>

<style>
  .prose-case :global(h2) {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: #0D0D0D;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #E2DED8;
  }

  .prose-case :global(h3) {
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #0D0D0D;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose-case :global(p) {
    color: #3A3A3A;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    max-width: 68ch;
  }

  .prose-case :global(strong) {
    color: #0D0D0D;
    font-weight: 600;
  }

  .prose-case :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 1.25rem;
    max-width: 68ch;
  }

  .prose-case :global(ul li) {
    color: #3A3A3A;
    line-height: 1.75;
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .prose-case :global(ul li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: #1B3BFF;
    font-weight: 500;
  }

  .prose-case :global(hr) {
    border: none;
    border-top: 1px solid #E2DED8;
    margin: 2.5rem 0;
  }

  .prose-case :global(code) {
    font-family: 'Geist Mono', monospace;
    font-size: 0.8em;
    background: #F0EDE8;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: #0D0D0D;
  }
</style>
